# Custom Devstral configuration for medmcp tool-calling.
#
# Default Ollama num_ctx is 2048 tokens — far too small for MCP tool schemas.
# medmcp's 8 tools consume ~1500 tokens of schema alone, leaving almost nothing
# for system prompt + conversation. 32768 matches Devstral's trained context
# and gives ample room for tool definitions + multi-turn dialogue.
#
# Low temperature keeps tool-call argument generation deterministic.
#
# Build with:
#   ollama create devstral-medmcp -f Modelfile.devstral

FROM devstral-small-2:latest

PARAMETER num_ctx 32768
PARAMETER temperature 0.1
